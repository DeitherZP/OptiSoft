@page "/users"
@attribute [Authorize]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Data.Users
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Pages.Users.Shared

@inject UsuariosService UsuariosService
@inject PersonalService PersonalService
@inject IJSRuntime JS

<PageTitle>Usuarios</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

@if (!IsFirstRender)
{
	<div class="nueva-fila">
		<FluentButton Appearance="Appearance.Accent" OnClick="@AddUser" IconStart="@(new Icons.Filled.Size20.AddCircle())" Style="margin-right: 3em">Nuevo</FluentButton>

		<FluentTextField Placeholder="Buscar por usuario, personal o sucursal..."
						 Style="width: 300px; margin-right: 1em;"
						 @bind-Value="TextoBusqueda"
						 @bind-Value:after="FiltrarUsuario" />

		<FluentButton Appearance="Appearance.Accent" OnClick="LimpiarFiltro" IconStart="@(new Icons.Filled.Size20.FilterDismiss())" Disabled="@(string.IsNullOrEmpty(TextoBusqueda))" />
	</div>
}

@if (ListUser != null)
{
	<FluentCard AreaRestricted="false" Class="data-grid-table" Style="max-height: 80vh; padding: 0.5em;">
		<FluentDataGrid Items="ListUser"
						TGridItem="ApplicationUser"
						Pagination="@pagination"
						AutoFit="true"
						ShowHover="true"
						DisplayMode="DataGridDisplayMode.Table"
						OnRowClick="@(args => OnRowClicked(args?.Item ?? new ApplicationUser()))">
			<PropertyColumn Property="a => a.UserName" Title="Usuario" Sortable="true" Align="Align.Center" IsDefaultSortColumn />
			<PropertyColumn Property="a => a.NombrePersonal" Title="Personal" Sortable="true" Align="Align.Center" />
			<PropertyColumn Property="a => a.NombreSucursal" Title="Sucursal" Sortable="true" Align="Align.Center" />
			<TemplateColumn Title="Cambiar Contraseña" Sortable="true" Align="Align.Center">
				<ChildContent Context="tbl">
					<FluentCheckbox Checked="@tbl.ForcePasswordChange" ReadOnly="true" />
				</ChildContent>
			</TemplateColumn>
		</FluentDataGrid>
		@if (ListUser.Count() > pagination.ItemsPerPage)
		{
			<FluentPaginator State="pagination" Style="padding: 0.5em 2em;" />
		}
	</FluentCard>
}

@if (!HiddenUser)
{
	<UserDiag Hidden="@HiddenUser"
			  HiddenChanged="@(v => HiddenUser = v)"
			  User="UserSeleccionado"
			  Personals="Personals"
			  OnGuardar="GuardarUsuario"
			  OnEliminar="EliminarUsuario" />
}

@code {
	private bool IsLoading = false;
	private bool IsFirstRender = true;
	private bool HiddenUser = true;

	PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

	private IQueryable<ApplicationUser>? ListUser;
	private List<ApplicationUser>? AuxUser = new();
	private List<ApplicationUser>? UsersFiltrados = new();
	private ApplicationUser? UserSeleccionado;
	private List<Personal>? Personals = new();
	private string? TextoBusqueda;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender)
			return;

		await JS.InvokeVoidAsync("translateFluentLabels");

		try
		{
			IsLoading = true;
			StateHasChanged();
			AuxUser = await UsuariosService.ObtenerUsuariosAsync();
			UsersFiltrados = new List<ApplicationUser>(AuxUser);
			ListUser = UsersFiltrados.AsQueryable();
			ListUser = AuxUser.AsQueryable();
		}
		catch (Exception ex)
		{
			ToastService.ShowError($"Error al cargar los datos. {ex.Message}", 5000);
		}
		finally
		{
			IsLoading = false;
			IsFirstRender = false;
			StateHasChanged();
		}

		IsFirstRender = false;
	}

	private async Task AddUser()
	{
		await CargarPersonal();
		UserSeleccionado = null;
		HiddenUser = false;
		StateHasChanged();
	}

	private async Task CargarPersonal()
	{
		try
		{
			IsLoading = true;
			StateHasChanged();

			Personals = await PersonalService.ObtenerPersonalAsync();
		}
		catch (Exception ex)
		{
			ToastService.ShowError($"Error al cargar datos del personal: {ex}", 5000);
		}
		finally
		{
			IsLoading = false;
			StateHasChanged();
		}
	}

	private async Task OnRowClicked(ApplicationUser user)
	{
		if (string.IsNullOrEmpty(user.UserName))
			return;

		await CargarPersonal();
		UserSeleccionado = user;
		HiddenUser = false;
		StateHasChanged();
	}

	private async Task GuardarUsuario()
	{
		AuxUser = await UsuariosService.ObtenerUsuariosAsync();
		UsersFiltrados = new List<ApplicationUser>(AuxUser);
		ListUser = UsersFiltrados.AsQueryable();
		UserSeleccionado = null;
		ToastService.ShowSuccess("Usuario guardado correctamente.");
	}

	private async Task EliminarUsuario()
	{
		AuxUser = await UsuariosService.ObtenerUsuariosAsync();
		UsersFiltrados = new List<ApplicationUser>(AuxUser);
		ListUser = UsersFiltrados.AsQueryable();
		UserSeleccionado = null;
		ToastService.ShowSuccess("Usuario eliminado correctamente");
	}

	private void LimpiarFiltro()
	{
		TextoBusqueda = null;
		FiltrarUsuario();
	}

	private void FiltrarUsuario()
	{
		if (AuxUser == null)
			return;

		if (string.IsNullOrWhiteSpace(TextoBusqueda))
		{
			UsersFiltrados = new List<ApplicationUser>(AuxUser);
		}
		else
		{
			var texto = TextoBusqueda.Trim().ToLower();

			UsersFiltrados = AuxUser
				.Where(p =>
					(!string.IsNullOrEmpty(p.UserName) && p.UserName.ToLower().Contains(texto)) ||
					(!string.IsNullOrEmpty(p.NombrePersonal) && p.NombrePersonal.ToLower().Contains(texto)) ||
					(!string.IsNullOrEmpty(p.NombreSucursal) && p.NombreSucursal.ToLower().Contains(texto))
				)
				.ToList();
		}

		ListUser = UsersFiltrados.AsQueryable();
		StateHasChanged();
	}
}
