@page "/pedido"
@attribute [Authorize(Policy = "RequirePasswordChanged")]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Helpers
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Services

@inject CompraService CompraService
@inject ClienteService ClienteService
@inject ArticuloService ArticuloService
@inject DetCompraService DetCompraService
@inject IJSRuntime JS

<PageTitle>Pedido</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

<div class="op-page">

    @if (!IsFirstRender)
    {
        <div class="op-topbar">
            <div class="op-topbar-left">
                @* <div class="op-greet">📋 Gestión de pedidos</div> *@
                <div class="op-title">📋 Pedidos</div>
            </div>
            <div class="op-topbar-right">

                @if (ListPedidos != null)
                {
                    <div class="op-stat-chip">
                        Total: <strong>@ListPedidos.Count()</strong>
                    </div>
                }

                <div class="op-search">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#8a8fbf" stroke-width="2">
                        <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
                    </svg>
                    <input placeholder="Buscar por cliente o número..."
                           autocomplete="off"
                           value="@TextoBusqueda"
                           @oninput="OnSearchInput" />
                </div>

                <button class="op-btn op-btn-ghost"
                        @onclick="LimpiarFiltro"
                        disabled="@(string.IsNullOrEmpty(TextoBusqueda))"
                        title="Limpiar filtro">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>

                @if (Permisos.CanCreate("/pedido"))
                {
                    <button class="op-btn" @onclick="AddPedido">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" />
                        </svg>
                        Nuevo pedido
                    </button>
                }
            </div>
        </div>
    }

    @if (ListPedidos != null)
    {
        <div class="op-card">
            <div class="op-card-header">
                <span class="op-card-title">Listado de pedidos</span>
                @if (!string.IsNullOrWhiteSpace(TextoBusqueda))
                {
                    <span class="op-card-count">@ListPedidos.Count() resultado(s) para "@TextoBusqueda"</span>
                }
            </div>

            @{
                var paginados    = ListPedidos.Skip(PaginaActual * ItemsPorPagina).Take(ItemsPorPagina).ToList();
                var totalPaginas = (int)Math.Ceiling(ListPedidos.Count() / (double)ItemsPorPagina);
            }

            @if (!paginados.Any())
            {
                <div class="op-empty">
                    <span class="op-empty-icon">🔍</span>
                    No se encontraron pedidos con ese criterio.
                </div>
            }
            else
            {
                <table class="op-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Número</th>
                            <th>Cliente</th>
                            <th>Laboratorio</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tbl in paginados)
                        {
                            <tr @onclick="@(() => OnRowClicked(tbl))">
                                <td class="td-date">@(tbl.Fecha?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                                <td class="td-code">@tbl.Numero</td>
                                <td class="td-name">@tbl.Cliente?.Nombre</td>
                                <td class="td-muted">@tbl.Laboratorio</td>
                                <td>
                                    @if (tbl.Finalizado)
                                    {
                                        <span class="op-pill op-pill--green">Finalizado</span>
                                    }
                                    else
                                    {
                                        <span class="op-pill op-pill--yellow">Pendiente</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (totalPaginas > 1)
                {
                    <div class="op-pagination">
                        <span class="op-page-info">
                            Página @(PaginaActual + 1) de @totalPaginas
                        </span>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual == 0)"
                                @onclick="() => CambiarPagina(PaginaActual - 1)">
                            ‹
                        </button>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual >= totalPaginas - 1)"
                                @onclick="() => CambiarPagina(PaginaActual + 1)">
                            ›
                        </button>
                    </div>
                }
            }
        </div>
    }

</div>

@if (!HiddenPedido)
{
    <PedidoDiag HiddenPedido="@HiddenPedido"
                Compra="PedidoSeleccionado"
                Clientes="Clientes"
                HiddenPedidoChanged="@(v => HiddenPedido = v)"
                DetCompras="ListDetCompras"
                OnGuardar="GuardarPedido"
                OnEliminar="EliminarPedido"/>
}

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Compra>? pedidos = new();
    private List<Compra>? pedidosFiltrados = new();
    bool HiddenPedido = true;
    private List<DetCompra>? ListDetCompras;
    bool IsFirstRender = true;
    private Compra? PedidoSeleccionado;
    private IQueryable<Compra>? ListPedidos;
    private List<Cliente> Clientes { get; set; } = new();
    private string? TextoBusqueda;

    private bool IsLoading { get; set; } = false;

    // Paginación propia
    private int PaginaActual   = 0;
    private int ItemsPorPagina = 10;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!Permisos.CanView("/pedido"))
            NavManager.NavigateTo("/noaccess");

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            pedidos = await CompraService.ObtenerPedidosAsync();
            pedidosFiltrados = new List<Compra>(pedidos);
            ListPedidos = pedidosFiltrados.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cargar los datos.", 5000);
            Console.WriteLine($"Error al cargar los datos: {ex}");
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddPedido()
    {
        IsLoading = true;
        StateHasChanged();

        Clientes = await ClienteService.ObtenerClienteAsync();
        PedidoSeleccionado = null;
        HiddenPedido = false;

        IsLoading = false;
        StateHasChanged();
    }

    private async Task GuardarPedido(Compra pedido)
    {
        pedidos = await CompraService.ObtenerPedidosAsync();
        pedidosFiltrados = new List<Compra>(pedidos);
        ListPedidos = pedidosFiltrados.AsQueryable();
        ToastService.ShowSuccess("Pedido guardado correctamente.");
    }

    private async Task EliminarPedido()
    {
        pedidos = await CompraService.ObtenerPedidosAsync();
        pedidosFiltrados = new List<Compra>(pedidos);
        ListPedidos = pedidosFiltrados.AsQueryable();
        ToastService.ShowSuccess("El pedido ha sido eliminado correctamente");
    }

    private async Task OnRowClicked(Compra compra)
    {
        if (compra.IdCompra <= 0)
            return;

        IsLoading = true;
        StateHasChanged();

        Clientes = await ClienteService.ObtenerClienteAsync();
        ListDetCompras = await DetCompraService.ObtenerDetComprasAsync(compra.IdCompra);
        PedidoSeleccionado = compra;

        HiddenPedido = false;
        IsLoading = false;
        StateHasChanged();
    }

    private void LimpiarFiltro()
    {
        TextoBusqueda = null;
        PaginaActual  = 0;
        FiltrarPedidos();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        TextoBusqueda = e.Value?.ToString();
        PaginaActual  = 0;
        FiltrarPedidos();
    }

    private void FiltrarPedidos()
    {
        if (pedidos == null)
            return;

        if (string.IsNullOrWhiteSpace(TextoBusqueda))
        {
            pedidosFiltrados = new List<Compra>(pedidos);
        }
        else
        {
            var texto = TextoBusqueda.Trim().ToLower();

            pedidosFiltrados = pedidos
                .Where(p =>
                    (!string.IsNullOrEmpty(p.Numero)          && p.Numero.ToLower().Contains(texto)) ||
                    (!string.IsNullOrEmpty(p.Cliente?.Nombre) && p.Cliente.Nombre.ToLower().Contains(texto))
                )
                .ToList();
        }

        ListPedidos = pedidosFiltrados.AsQueryable();
        StateHasChanged();
    }

    private void CambiarPagina(int nuevaPagina)
    {
        PaginaActual = nuevaPagina;
        StateHasChanged();
    }
}
