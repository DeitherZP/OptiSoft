@page "/pedido"
@attribute [Authorize]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Services

@inject CompraService CompraService
@inject ClienteService ClienteService
@inject ArticuloService ArticuloService
@inject DetCompraService DetCompraService
@inject IJSRuntime JS

<PageTitle>Pedido</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

@if (!IsFirstRender)
{
    <div class="nueva-fila">
        <FluentButton Appearance="Appearance.Accent" OnClick="@AddPedido" IconStart="@(new Icons.Filled.Size20.AddCircle())" Style="margin-top: 1.45em; margin-right: 3em">Nuevo</FluentButton>
        
        <FluentAutocomplete Label="Cliente"
                            Items="Clientes"
                            TOption="Cliente"
                            Class="autocomplete-opti"
                            @bind-SelectedOption="ClienteSelect"
                            OptionText="@(c => c.Nombre)"
                            Virtualize="true"
                            Multiple="false"
                            MaximumOptionsSearch="int.MaxValue"
                            MaximumSelectedOptions="1"
                            Position="SelectPosition.Below"
                            @bind-SelectedOption:after="FiltrarPorCliente"
                            Style="width: 300px; margin-right: 1em;" />

        <FluentButton Appearance="Appearance.Accent" OnClick="LimpiarFiltro" IconStart="@(new Icons.Filled.Size20.FilterDismiss())" Style="margin-top: 1.45em;" Disabled="!(ClienteSelect?.idCliente > 0)" />
    </div>
}

@if (!(ListPedidos == null))
{
    <FluentCard AreaRestricted="false" Class="data-grid-table" Style="max-height: 78vh; padding: 0.5em;">
        <FluentDataGrid Items="ListPedidos"
                        TGridItem="Compra"
                        Pagination="@pagination"
                        AutoFit=true
                        ShowHover=true
                        DisplayMode="DataGridDisplayMode.Table"
                        OnRowClick="@(args => OnRowClicked(args?.Item ?? new Compra()))">
            <PropertyColumn Property="tbl => tbl.Fecha" Title="Fecha" Sortable="true" Format="dd/MM/yyyy" IsDefaultSortColumn InitialSortDirection="SortDirection.Descending" />
            <PropertyColumn Property="tbl => tbl.Numero" Title="Número" Sortable="true" />
            <PropertyColumn Property="tbl => tbl.Cliente!.Nombre" Title="Cliente" Sortable="true" />
            <PropertyColumn Property="tbl => tbl.Laboratorio" Title="Laboratorio" Sortable="false" />
            <TemplateColumn Title="Estado" Sortable="true">
                <ChildContent Context="tbl">
                    @(tbl.Finalizado ? "Finalizado" : "Pendiente")
                </ChildContent>
            </TemplateColumn>
        </FluentDataGrid>
        @if (ListPedidos.Count() > pagination.ItemsPerPage)
        {
            <FluentPaginator State="pagination" Style="padding: 0.5em 2em;" />
        }
    </FluentCard>
}

@if (!Hidden)
{
    <PedidoDiag Hidden="@Hidden"
                Compra="PedidoSeleccionado"
                Clientes="Clientes"
                HiddenChanged="@(v => Hidden = v)"
                DetCompras="ListDetCompras"
                OnGuardar="GuardarPedido"
                OnEliminar="EliminarPedido"/>
}

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Compra>? pedidos = new();
    private List<Compra>? pedidosFiltrados = new();
    bool Hidden = true;
    private List<DetCompra>? ListDetCompras;
    bool IsFirstRender = true;
    private Compra? PedidoSeleccionado;
    private IQueryable<Compra>? ListPedidos;
    private List<Cliente> Clientes { get; set; } = new();
    private Cliente? ClienteSelect { get; set; }

    private bool IsLoading { get; set; } = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            pedidos = await CompraService.ObtenerPedidosAsync();
            pedidosFiltrados = new List<Compra>(pedidos);
            Clientes = await ClienteService.ObtenerClienteAsync();
            ListPedidos = pedidosFiltrados.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cargar los datos.", 5000);
            Console.WriteLine($"Error al cargar los datos: {ex}");
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddPedido()
    {
        IsLoading = true;
        StateHasChanged();

        PedidoSeleccionado = null;
        Hidden = false;

        IsLoading = false;
        StateHasChanged();
    }

    private async Task GuardarPedido(Compra pedido)
    {
        pedidos = await CompraService.ObtenerPedidosAsync();
        pedidosFiltrados = new List<Compra>(pedidos);
        ListPedidos = pedidosFiltrados.AsQueryable();
        ClienteSelect = null;
        ToastService.ShowSuccess("Pedido guardado correctamente");
    }

    private async Task EliminarPedido()
    {
        pedidos = await CompraService.ObtenerPedidosAsync();
        pedidosFiltrados = new List<Compra>(pedidos);
        ListPedidos = pedidosFiltrados.AsQueryable();
        ClienteSelect = null;
        ToastService.ShowSuccess("El pedido ha sido eliminado correctamente");
    }

    private async Task OnRowClicked(Compra compra)
    {
        if (compra.idCompra <= 0)
            return;

        IsLoading = true;
        StateHasChanged();

        ListDetCompras = await DetCompraService.ObtenerDetComprasAsync(compra.idCompra);
        PedidoSeleccionado = compra;

        Hidden = false;
        IsLoading = false;
        StateHasChanged();
    }

    private void FiltrarPorCliente()
    {
        if (pedidos == null) return;

        if (ClienteSelect?.idCliente > 0)
        {
            pedidosFiltrados = pedidos
                .Where(c => c.Cliente?.idCliente == ClienteSelect.idCliente)
                .ToList();
        }
        else
        {
            pedidosFiltrados = new List<Compra>(pedidos);
        }

        ListPedidos = pedidosFiltrados.AsQueryable();
        StateHasChanged();
    }

    private void LimpiarFiltro()
    {
        ClienteSelect = null;
        FiltrarPorCliente();
    }
}
