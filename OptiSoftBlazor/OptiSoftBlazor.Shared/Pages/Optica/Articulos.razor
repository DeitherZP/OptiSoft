@page "/articulos"
@attribute [Authorize(Policy = "RequirePasswordChanged")]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Helpers
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Pages.Shared

@inject ArticuloService ArticuloService
@inject IJSRuntime JS

<PageTitle>Artículos</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

<div class="op-page">

    @if (!IsFirstRender)
    {
        <!-- Topbar -->
        <div class="op-topbar">
            <div class="op-topbar-left">
                <div class="op-title">📦 Artículos</div>
            </div>
            <div class="op-topbar-right">

                @if (ListArt != null)
                {
                    <div class="op-stat-chip">
                        Total: <strong>@ListArt.Count()</strong>
                    </div>
                }

                <div class="op-search">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#8a9ab5" stroke-width="2">
                        <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
                    </svg>
                    <input placeholder="Buscar por artículo o código..."
                           value="@TextoBusqueda"
                           @oninput="OnSearchInput" />
                </div>

                <button class="op-btn op-btn-ghost"
                        @onclick="LimpiarFiltro"
                        disabled="@(string.IsNullOrEmpty(TextoBusqueda))"
                        title="Limpiar filtro">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>

                @if (Permisos.CanCreate("/articulos"))
                {
                    <button class="op-btn" @onclick="AddArticulo">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" />
                        </svg>
                        Nuevo artículo
                    </button>
                }
            </div>
        </div>
    }

    <!-- Table card -->
    @if (ListArt != null)
    {
        <div class="op-card">
            <div class="op-card-header">
                <span class="op-card-title">Listado de artículos</span>
                @if (!string.IsNullOrWhiteSpace(TextoBusqueda))
                {
                    <span class="op-card-count">@ListArt.Count() resultado(s) para "@TextoBusqueda"</span>
                }
            </div>

            @{
                var paginados = ListArt.Skip(PaginaActual * ItemsPorPagina).Take(ItemsPorPagina).ToList();
                var totalPaginas = (int)Math.Ceiling(ListArt.Count() / (double)ItemsPorPagina);
            }

            @if (!paginados.Any())
            {
                <div class="op-empty">
                    <span class="op-empty-icon">🔍</span>
                    No se encontraron artículos con ese criterio.
                </div>
            }
            else
            {
                <table class="op-table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Artículo</th>
                            <th style="text-align:right;">Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var art in paginados)
                        {
                            <tr @onclick="@(() => OnRowClicked(art))">
                                <td class="td-code">@art.Codigo</td>
                                <td class="td-name">@art.Nombre</td>
                                <td class="td-price" style="text-align:right;">
                                    @art.Precio2.ToString("C")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (totalPaginas > 1)
                {
                    <div class="op-pagination">
                        <span class="op-page-info">
                            Página @(PaginaActual + 1) de @totalPaginas
                        </span>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual == 0)"
                                @onclick="() => CambiarPagina(PaginaActual - 1)">
                            ‹
                        </button>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual >= totalPaginas - 1)"
                                @onclick="() => CambiarPagina(PaginaActual + 1)">
                            ›
                        </button>
                    </div>
                }
            }
        </div>
    }

</div>

@if (!HiddenArtView)
{
    <ArticuloViewDiag HiddenArtView="@HiddenArtView"
                      Articulo="@ArticuloSeleccionado"
                      HiddenArtViewChanged="@(v => HiddenArtView = v)"
                      OnGuardar="GuardarArticulo"
                      OnEliminar="EliminarArticulo" />
}

@code {
    private List<Articulo>? AuxArticulos = new();
    private List<Articulo>? ArticulosFiltrados = new();
    private Articulo? ArticuloSeleccionado;
    private IQueryable<Articulo>? ListArt;

    bool HiddenArtView = true;
    bool IsFirstRender = true;
    private bool IsLoading = false;
    private string? TextoBusqueda;

    // Paginación propia (reemplaza FluentPaginator)
    private int PaginaActual = 0;
    private int ItemsPorPagina = 10;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!Permisos.CanView("/articulos"))
            NavManager.NavigateTo("/noaccess");

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
            ArticulosFiltrados = new List<Articulo>(AuxArticulos);
            ListArt = ArticulosFiltrados.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al cargar los datos. {ex.Message}", 5000);
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void AddArticulo()
    {
        ArticuloSeleccionado = null;
        HiddenArtView = false;
        StateHasChanged();
    }

    private async Task OnRowClicked(Articulo articulo)
    {
        if (articulo.IdArticulo <= 0)
            return;

        ArticuloSeleccionado = articulo;
        HiddenArtView = false;
        StateHasChanged();
    }

    private async Task GuardarArticulo(Articulo articulo)
    {
        AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
        ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        ListArt = ArticulosFiltrados.AsQueryable();
        ToastService.ShowSuccess("Artículo guardado correctamente");
    }

    private async Task EliminarArticulo()
    {
        AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
        ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        ListArt = ArticulosFiltrados.AsQueryable();
        ToastService.ShowSuccess("El artículo ha sido eliminado correctamente");
    }

    private void LimpiarFiltro()
    {
        TextoBusqueda = null;
        PaginaActual = 0;
        FiltrarArticulos();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        TextoBusqueda = e.Value?.ToString();
        PaginaActual = 0;
        FiltrarArticulos();
    }

    private void FiltrarArticulos()
    {
        if (AuxArticulos == null)
            return;

        if (string.IsNullOrWhiteSpace(TextoBusqueda))
        {
            ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        }
        else
        {
            var texto = TextoBusqueda.Trim().ToLower();
            ArticulosFiltrados = AuxArticulos
                .Where(p =>
                    (!string.IsNullOrEmpty(p.Nombre) && p.Nombre.ToLower().Contains(texto)) ||
                    (!string.IsNullOrEmpty(p.Codigo) && p.Codigo.ToLower().Contains(texto)))
                .ToList();
        }

        ListArt = ArticulosFiltrados.AsQueryable();
        StateHasChanged();
    }

    private void CambiarPagina(int nuevaPagina)
    {
        PaginaActual = nuevaPagina;
        StateHasChanged();
    }
}
