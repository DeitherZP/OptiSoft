@page "/articulos"
@attribute [Authorize(Policy = "RequirePasswordChanged")]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Helpers
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Pages.Shared

@inject ArticuloService ArticuloService
@inject IJSRuntime JS

<PageTitle>Artículos</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

@if (!IsFirstRender)
{
    <div class="nueva-fila">
        @if (Permisos.CanCreate("/articulos"))
        {
            <FluentButton Appearance="Appearance.Accent" OnClick="@AddArticulo" IconStart="@(new Icons.Filled.Size20.AddCircle())" Style="margin-right: 3em">Nuevo</FluentButton>
        }

        <FluentTextField Placeholder="Buscar por artículo o código..."
                         Style="width: 300px; margin-right: 1em;"
                         @bind-Value="TextoBusqueda"
                         @bind-Value:after="FiltrarArticulos" />

        <FluentButton Appearance="Appearance.Accent" OnClick="LimpiarFiltro" IconStart="@(new Icons.Filled.Size20.FilterDismiss())" Disabled="@(string.IsNullOrEmpty(TextoBusqueda))" />
    </div>
}

@if (!(ListArt == null))
{
    <FluentCard AreaRestricted="false" Class="data-grid-table" Style="max-height: 80vh; padding: 0.5em;">
        <FluentDataGrid Items="ListArt"
                        TGridItem="Articulo"
                        Pagination="@pagination"
                        AutoFit="true"
                        ShowHover="true"
                        DisplayMode="DataGridDisplayMode.Table"
                        OnRowClick="@(args => OnRowClicked(args?.Item ?? new Articulo()))">
            <PropertyColumn Property="art => art.Codigo" Title="Código" Sortable="true" Align="Align.Center" />
            <PropertyColumn Property="art => art.Nombre" Title="Artículo" Sortable="true" Align="Align.Center" IsDefaultSortColumn />
            <PropertyColumn Property="art => art.Precio2" Title="Precio" Sortable="true" Align="Align.Center" />
        </FluentDataGrid>
        @if (ListArt.Count() > pagination.ItemsPerPage)
        {
            <FluentPaginator State="pagination" Style="padding: 0.5em 2em;" />
        }
    </FluentCard>
}

@if (!HiddenArtView)
{
    <ArticuloViewDiag HiddenArtView="@HiddenArtView"
                      Articulo="@ArticuloSeleccionado"
                      HiddenArtViewChanged="@(v => HiddenArtView = v)"
                      OnGuardar="GuardarArticulo"
                      OnEliminar="EliminarArticulo"/>
}

@code{
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Articulo>? AuxArticulos = new();
    private List<Articulo>? ArticulosFiltrados = new();
    private Articulo? ArticuloSeleccionado;
    private IQueryable<Articulo>? ListArt;
    bool HiddenArtView = true;
    bool IsFirstRender = true;
    private bool IsLoading = false;
    private string? TextoBusqueda;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!Permisos.CanView("/articulos"))
            NavManager.NavigateTo("/noaccess");

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
            ArticulosFiltrados = new List<Articulo>(AuxArticulos);
            ListArt = ArticulosFiltrados.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al cargar los datos. {ex.Message}", 5000);
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void AddArticulo()
    {
        HiddenArtView = false;
        StateHasChanged();
    }

    private async Task OnRowClicked(Articulo articulo)
    {
        if (articulo.IdArticulo <= 0)
            return;

        ArticuloSeleccionado = articulo;
        HiddenArtView = false;
        StateHasChanged();
    }

    private async Task GuardarArticulo(Articulo articulo)
    {
        AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
        ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        ListArt = ArticulosFiltrados.AsQueryable();
        ToastService.ShowSuccess("Pedido guardado correctamente");
    }

    private async Task EliminarArticulo()
    {
        AuxArticulos = await ArticuloService.ObtenerArticulosAsync();
        ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        ListArt = ArticulosFiltrados.AsQueryable();
        ToastService.ShowSuccess("El pedido ha sido eliminado correctamente");
    }

    private void LimpiarFiltro()
    {
        TextoBusqueda = null;
        FiltrarArticulos();
    }

    private void FiltrarArticulos()
    {
        if (AuxArticulos == null)
            return;

        if (string.IsNullOrWhiteSpace(TextoBusqueda))
        {
            ArticulosFiltrados = new List<Articulo>(AuxArticulos);
        }
        else
        {
            var texto = TextoBusqueda.Trim().ToLower();

            ArticulosFiltrados = AuxArticulos
                .Where(p =>
                    (!string.IsNullOrEmpty(p.Nombre) && p.Nombre.ToLower().Contains(texto)) ||
                    (!string.IsNullOrEmpty(p.Codigo) && p.Codigo.ToLower().Contains(texto))
                )
                .ToList();
        }

        ListArt = ArticulosFiltrados.AsQueryable();
        StateHasChanged();
    }
}