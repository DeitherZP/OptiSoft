@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Data.DTO
@using OptiSoftBlazor.Shared.Services

@inject ArticuloService ArticuloService;

<style>
    .container-modal-articulo .fluent-dialog-main {
        --dialog-width: 650px !important;
        --dialog-max-height: 90vh !important;
    }

    @@media (max-width: 600px) {
        .container-modal-articulo .fluent-dialog-main {
            --dialog-width: 90% !important;
            --dialog-max-height: 90vh !important;
        }
    }

    .autocomplete-articulo fluent-anchored-region {
        min-width: 555px;
        max-width: 555px;
        min-height: 100px !important;
        max-height: 100px !important;
    }

        .autocomplete-articulo fluent-anchored-region fluent-option {
        margin: 0 0.5em 0 0.2em;
    }
</style>

<div class="container-modal-articulo">
    <FluentDialog Modal="true" @bind-Hidden="HiddenArticulo">
        <FluentHeader>Seleccione un artículo</FluentHeader>

        <FluentDialogBody Style="overflow: visible;">
            <div style="padding: 0.5em;">
                <div class="columna-flex" style="padding: 0 1em; margin-right: 0; margin-bottom: 1.5em;">
                    <FluentNumberField @bind-Value="Cantidad"
                                       Label="Cantidad"
                                       Placeholder="Ingrese la cantidad"/>
                </div>
                <div class="columna-flex" style="padding: 0 1em; margin-right: 0;">
                    <FluentAutocomplete Label="Artículo"
                                        Items="@Articulos"
                                        TOption="Articulo"
                                        Class="autocomplete-articulo"
                                        @bind-SelectedOption="ArticuloSelect"
                                        OptionText="@(a => a.Nombre)"
                                        Multiple="false"
                                        Virtualize="true"
                                        MaximumOptionsSearch="int.MaxValue"
                                        MaximumSelectedOptions="1"
                                        Placeholder="Seleccione un artículo"
                                        MaxAutoHeight="100px"
                                        Position="SelectPosition.Below" />
                </div>
            </div>
        </FluentDialogBody>

        <FluentFooter Style="gap: 1em;">
            <FluentButton Appearance="Appearance.Stealth"
                          OnClick="Cerrar"
                          IconStart="@(new Icons.Filled.Size20.DismissCircle())">
                Cerrar
            </FluentButton>

            <FluentButton Appearance="Appearance.Accent"
                          OnClick="Agregar"
                          IconStart="@(new Icons.Filled.Size20.AddCircle())">
                Agregar
            </FluentButton>
        </FluentFooter>
    </FluentDialog>
</div>

@code{
    [Parameter] public bool HiddenArticulo { get; set; }
    [Parameter] public EventCallback<bool> HiddenArticuloChanged { get; set; }
    [Parameter] public List<Articulo> Articulos { get; set; } = new();
    [Parameter] public EventCallback<Articulo> OnGuardar { get; set; }
    [Parameter] public Articulo? ArticuloSelect { get; set; }
    [Parameter] public EventCallback<ArticuloAgregadoEvent> OnArticuloAgregado { get; set; }

    int Cantidad { get; set; } = 1;

    private async Task Cerrar()
    {
        HiddenArticulo = true;
        ArticuloSelect = null;
        Cantidad = 1;
        await HiddenArticuloChanged.InvokeAsync(HiddenArticulo);
    }

    private async Task Agregar()
    {
        if (ArticuloSelect == null)
        {
            ToastService.ShowWarning("Debe seleccionar un artículo", 5000);
            return;
        }

        var articulo = new ArticuloAgregadoEvent
        {
            Articulo = ArticuloSelect,
            Cantidad = Cantidad
        };

        await OnArticuloAgregado.InvokeAsync(articulo);
        await Cerrar();
    }
}
