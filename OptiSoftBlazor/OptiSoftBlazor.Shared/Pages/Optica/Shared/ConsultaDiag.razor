    private void FiltrarPedidoCliente()
    {
        PedidoSelect = null;
        _consulta.IdPedido = null;

        if (ClienteSelect == null)
        {
            Pedidos = new List<Compra>();
            activarPedido = false;
            StateHasChanged();
            return;
        }

        Pedidos = _pedidosOriginales
            .Where(p => p.IdCliente == ClienteSelect.IdCliente)
            .ToList();

        if (Pedidos.Count == 0)
        {
            ToastService.ShowInfo("El cliente seleccionado no tiene ningún pedido registrado.", 5000);
            activarPedido = false;
            StateHasChanged();
            return;
        }

        activarPedido = true;
        StateHasChanged();
    }

