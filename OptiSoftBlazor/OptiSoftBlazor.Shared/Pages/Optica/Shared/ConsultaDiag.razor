@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Services
@using OptiSoftBlazor.Shared.Helpers

@inject IJSRuntime JS
@inject ClienteService ClienteService
@inject PersonalService PersonalService
@inject CompraService CompraService
@inject ConsultaService ConsultaService
@inject SeteoService SeteoService

<style>
    .fluent-dialog-main {
        --dialog-width: 1000px !important;
        --dialog-max-height: 95vh !important;
    }

    @@media (max-width: 600px) {
        .fluent-dialog-main {
            --dialog-width: 90% !important;
            --dialog-max-height: 90vh !important;
        }
    }

    .autocomplete-pedido fluent-anchored-region {
        min-width: 430px;
        max-width: 430px;
    }

    .autocomplete-pedido fluent-anchored-region fluent-option {
        margin: 0 0.5em 0 0.2em;
    }
</style>

<LoadingSpinner @bind-Visible="IsLoading" />

<FluentDialog Modal="true" @bind-Hidden="Hidden">
    <FluentHeader>
        <h3>@(Consulta == null ? "Nueva Consulta" : "Editar Consulta")</h3>
    </FluentHeader>

    <FluentDialogBody Style="overflow-y:auto; max-height: calc(80vh - 120px);">
        <div style="padding: 1em;">
            @if (_consulta?.IdConsulta > 0)
            {
                <div class="nueva-fila" style="gap: 2em;">
                    <div class="columna-flex" style="max-width: 20%;">
                        <FluentButton Class="btn-motor-refractivo"
                                      Appearance="Appearance.Neutral"
                                      OnClick="MotorRefractivo">
                            <FluentIcon Value="@(new Icons.Filled.Size20.Glasses())" Color="Color.Neutral" Slot="start" />
                            Motor Refractivo
                        </FluentButton>
                    </div>
                    <div class="columna-flex" style="max-width: 20%;">
                        <FluentButton Class="btn-lente-contacto"
                                      Appearance="Appearance.Neutral"
                                      OnClick="LenteContacto">
                            <FluentIcon Value="@(new Icons.Filled.Size20.Eye())" Color="Color.Neutral" Slot="start" />
                            Lente de Contacto
                        </FluentButton>
                    </div>
                </div>
            }
            <FluentCard AreaRestricted="false" Style="height: fit-content">
                    <FluentHeader>
                        Información de la consulta
                    </FluentHeader>

                <div style="padding: 0 1em;">
                    <div class="fila-flex">
                        <div class="columna-flex" style="padding-top: 1em;">
                            <FluentAutocomplete Label="Cliente"
                                                Items="@Clientes"
                                                TOption="Cliente"
                                                Class="autocomplete-opti"
                                                @bind-SelectedOption="ClienteSelect"
                                                OptionText="@(c => c.Nombre)"
                                                Multiple="false"
                                                Virtualize="true"
                                                MaximumSelectedOptions="1"
                                                MaximumOptionsSearch="int.MaxValue"
                                                @bind-SelectedOption:after="FiltrarPedidoCliente"
                                                Position="SelectPosition.Below" />
                        </div>
                    </div>
                    <div class="fila-flex">
                        <div class="columna-flex" style="padding-top: 1em;">
                            <FluentAutocomplete Label="Profesional"
                                                Items="@Personales"
                                                TOption="Personal"
                                                Class="autocomplete-opti"
                                                @bind-SelectedOption="ProfesionalSelect"
                                                OptionText="@(c => c.Nombre)"
                                                Multiple="false"
                                                Virtualize="true"
                                                MaximumSelectedOptions="1"
                                                MaximumOptionsSearch="int.MaxValue"
                                                Position="SelectPosition.Below" />
                        </div>
                    </div>
                    <div class="fila-flex">
                        <div class="columna-flex" style="padding-top: 1em;">
                            <FluentDatePicker Label="Fecha"
                                              @bind-Value="@_consulta!.Fecha" />
                        </div>
                        <div class="columna-flex" style="padding-top: 1em;">
                            <div class="fila-flex" style="gap: 0.5em;">
                                <div class="columna-flex" style="min-width: 90%; max-width: 90%;">
                                    <FluentAutocomplete Label="Pedido"
                                                        Items="@Pedidos"
                                                        TOption="Compra"
                                                        Class="autocomplete-pedido"
                                                        @bind-SelectedOption="PedidoSelect"
                                                        OptionText="@(c => c.Numero)"
                                                        Multiple="false"
                                                        Virtualize="true"
                                                        ReadOnly="@(!activarPedido)"
                                                        MaximumSelectedOptions="1"
                                                        MaximumOptionsSearch="int.MaxValue"
                                                        Position="SelectPosition.Below" />
                                </div>
                                <div class="columna-flex" style="margin-top: 1.7em; min-width: 8%; max-width: 8%;">
                                    <FluentButton Appearance="Appearance.Accent"
                                                  OnClick="AddPedido"
                                                  Disabled="@(ClienteSelect == null)"
                                                  IconStart="@(new Icons.Filled.Size20.Add())" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="nueva-fila" style="margin-top: 1em;">
                        <div class="columna-flex">
                            <FluentTextArea @bind-Value="@_consulta.Motivo" Label="Motivo de la consulta" Rows="4" />
                        </div>
                    </div>
                    <div class="nueva-fila" style="margin-top: 1em;">
                        <div class="columna-flex">
                            <FluentTextArea @bind-Value="@_consulta.AntPatoOcular" Label="Antecedentes patológicos oculares" Rows="4" />
                        </div>
                    </div>
                </div>
            </FluentCard>

            <FluentTabs Style="margin-top: 1em;">
                <FluentTab Label="Motor Refractivo">
                    <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em;">
                        <FluentHeader>
                            Rx en uso / Agudeza Visual
                        </FluentHeader>
                        
                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Derecho</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.RxUsoEsferaOD" Label="Esfera" TextFieldType="TextFieldType.Number"/>
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoCilindroOD" Label="Cilindro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoEjeOD" Label="Eje" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAddOD" Label="Add" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAvlOD" Label="Avl" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAvcOD" Label="Avc" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                        </div>
                        
                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Izquierdo</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.RxUsoEsferaOI" Label="Esfera" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoCilindroOI" Label="Cilindro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoEjeOI" Label="Eje" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAddOI" Label="Add" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAvlOI" Label="Avl" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxUsoAvcOI" Label="Avc" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                        </div>
                    </FluentCard>

                    <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em;">
                        <FluentHeader>
                            Rx Final
                        </FluentHeader>

                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Derecho</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.RxEsferaOD" Label="Esfera" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxCilindroOD" Label="Cilindro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxEjeOD" Label="Eje" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAddOD" Label="Add" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxDnpOD" Label="Dnp" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAltOD" Label="Alt" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAvlOD" Label="Avl" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAvcOD" Label="Avc" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                        </div>

                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Izquierdo</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.RxEsferaOI" Label="Esfera" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxCilindroOI" Label="Cilindro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxEjeOI" Label="Eje" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAddOI" Label="Add" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxDnpOI" Label="Dnp" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAltOI" Label="Alt" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAvlOI" Label="Avl" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.RxAvcOI" Label="Avc" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                        </div>
                    </FluentCard>

                    <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em;">
                        <FluentHeader Style="margin-bottom: 1em;">
                            Recomendaciones
                        </FluentHeader>
                        
                        <div style="padding: 0 1em;">
                            <div class="fila-flex">
                                <div class="columna-flex">
                                    <FluentTextArea @bind-Value="@_consulta!.TipoLente"
                                                    Label="Tipo Lente"
                                                    Placeholder="Descripción del tipo de lente"
                                                    Rows="3" />
                                </div>
                            </div>

                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Altura</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.AlturaOD" Label="Ojo Derecho" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.AlturaOI" Label="Ojo Izquierdo" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>

                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Diámetro del Armazón</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.DiamArmVertical" Label="D. Vertical" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.DiamArmHorizontal" Label="D. Horizontal" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.DiamArmPuente" Label="Puente" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.DiamArmMayor" Label="Mayor" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.DiamArmTipo" Label="Tipo" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>

                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Parámetros de Personalización</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.ParPersAP" Label="AP" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.ParPersCP" Label="CP" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.ParPersDV" Label="DV" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.ParPersCorredor" Label="Corredor" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>

                            <div class="fila-flex" style="margin-top: 1em;">
                                <div class="columna-flex">
                                    <FluentTextArea @bind-Value="@_consulta.Tratamiento"
                                                    Label="Tratamiento"
                                                    Placeholder="Tratamiento adicional"
                                                    Rows="4" />
                                </div>
                            </div>
                        </div>
                    </FluentCard>
                </FluentTab>
                <FluentTab Label="Lentes de Contacto">
                    <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em;">
                        <FluentHeader Style="margin-bottom: 1em;">
                            Queratometría
                        </FluentHeader>
                        
                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Derecho</h4>

                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.LC_KeraK1OD" Label="K1" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_KeraK2OD" Label="K2" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Izquierdo</h4>

                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.LC_KeraK1OI" Label="K1" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_KeraK2OI" Label="K2" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                            </FluentCard>
                        </div>
                    </FluentCard>
                    <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em;">
                        <FluentHeader Style="margin-bottom: 1em;">
                            Prueba
                        </FluentHeader>
                        
                        <div style="padding: 0 1em;">
                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Derecho</h4>

                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.LC_LFinRxOD" Label="Rx" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinTipoOD" Label="Tipo" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinCBOD" Label="CB" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinDiamOD" Label="Diámetro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinEspesorOD" Label="Espesor" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinSagitaOD" Label="Sagita" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextArea @bind-Value="@_consulta.LC_LFinDisenoOD" Label="Diseño Od" Placeholder="Ingrese el diseño para el ojo derecho" />
                                    </div>
                                </div>
                            </FluentCard>

                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0;">Ojo Izquierdo</h4>

                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta!.LC_LFinRxOI" Label="Rx" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinTipoOI" Label="Tipo" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinCBOI" Label="CB" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinDiamOI" Label="Diámetro" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinEspesorOI" Label="Espesor" TextFieldType="TextFieldType.Number" />
                                    </div>
                                    <div class="columna-flex">
                                        <FluentTextField @bind-Value="@_consulta.LC_LFinSagitaOI" Label="Sagita" TextFieldType="TextFieldType.Number" />
                                    </div>
                                </div>
                                <div class="fila-flex" style="margin-top: 1em;">
                                    <div class="columna-flex">
                                        <FluentTextArea @bind-Value="@_consulta.LC_LFinDisenoOI" Label="Diseño Oi" Placeholder="Ingrese el diseño para el ojo izquierdo" Rows="4" />
                                    </div>
                                </div>
                            </FluentCard>

                            <FluentCard AreaRestricted="false" Style="max-height: fit-content; margin-top: 1em; padding-top: 1em;">
                                <h4 style="margin-top: 0; margin-bottom: 0.5em;">Diagnóstico</h4>

                                <div class="fila-flex">
                                    <div class="columna-flex">
                                        <FluentTextArea @bind-Value="@_consulta!.LC_Diagnostico" Placeholder="Ingrese el diagnóstico" Rows="4"/>
                                    </div>
                                </div>
                            </FluentCard>
                        </div>
                    </FluentCard>
                </FluentTab>
            </FluentTabs>
        </div>
    </FluentDialogBody>

    <FluentFooter Style="gap:1em">
        <FluentButton Appearance="Appearance.Stealth"
                      OnClick="Cancelar"
                      IconStart="@(new Icons.Filled.Size20.DismissCircle())">
            Cancelar
        </FluentButton>

        @if (Consulta != null && Consulta?.IdConsulta > 0)
        {
            <FluentButton Class="btn-danger" 
                          Appearance="Appearance.Neutral"
                          OnClick="Eliminar" >
                <FluentIcon Value="@(new Icons.Filled.Size20.Delete())" Color="Color.Neutral" Slot="start" />
                Eliminar
            </FluentButton>
        }

        <FluentButton Appearance="Appearance.Accent"
                      OnClick="Guardar"
                      IconStart="@(new Icons.Filled.Size20.Save())">
            Guardar
        </FluentButton>
    </FluentFooter>
</FluentDialog>

@if (!HiddenPedido)
{
    <PedidoDiag Hidden="@HiddenPedido"
                ClienteConsulta="ClienteSelect"
                Clientes="Clientes"
                HiddenChanged="@(v => HiddenPedido = v)"
                OnGuardar="PedidoGuardado" />
}

@code {
    [Parameter] public bool Hidden { get; set; }
    [Parameter] public EventCallback<bool> HiddenChanged { get; set; }
    [Parameter] public List<Cliente> Clientes { get; set; } = new();
    [Parameter] public List<Personal> Personales { get; set; } = new();
    [Parameter] public List<Compra> Pedidos { get; set; } = new();
    [Parameter] public EventCallback<Consulta> OnGuardar { get; set; }
    [Parameter] public EventCallback OnEliminar { get; set; }
    [Parameter] public Consulta? Consulta { get; set; }

    private Consulta _consulta = new();
    private Cliente? ClienteSelect { get; set; }
    private Personal? ProfesionalSelect { get; set; }
    private Compra? PedidoSelect { get; set; }
    private List<Compra> _pedidosOriginales = new();
    private bool activarPedido = false;
    private bool HiddenPedido = true;

    private bool IsLoading = false;

    protected override void OnParametersSet()
    {
        if (_pedidosOriginales.Count == 0 && Pedidos.Any())
        {
            _pedidosOriginales = Pedidos.ToList();
        }

        FiltrarPedidoCliente();

        if (Consulta != null)
        {
            // Modo edición: copiar los datos de la consulta existente
            _consulta = new Consulta
            {
                IdConsulta = Consulta.IdConsulta,
                IdCliente = Consulta.IdCliente,
                IdProfesional = Consulta.IdProfesional,
                IdPedido = Consulta.IdPedido,
                Fecha = Consulta.Fecha,
                Motivo = Consulta.Motivo,
