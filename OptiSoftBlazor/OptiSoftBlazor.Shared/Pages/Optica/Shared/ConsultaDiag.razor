    private async Task PedidoGuardado(Compra pedido)
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            var todosPedidos = await CompraService.ObtenerPedidosAsync();
            _pedidosOriginales = todosPedidos;
            FiltrarPedidoCliente();
            PedidoSelect = Pedidos.FirstOrDefault(p => p.IdCompra == pedido.IdCompra);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al recargar datos: {ex.Message}", 5000);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
