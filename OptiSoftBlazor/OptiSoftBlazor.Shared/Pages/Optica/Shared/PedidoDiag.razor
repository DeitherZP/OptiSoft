@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Data.DTO
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Services
@using System.Threading.Tasks

@inject CompraService CompraService;
@inject ArticuloService ArticuloService;
@inject DetCompraService DetCompraService;
@inject ClienteService ClienteService

<style>
    .container-modal-pedido .fluent-dialog-main {
        --dialog-width: 850px !important;
        --dialog-max-height: 90vh !important;
    }

    @@media (max-width: 600px) {
        .container-modal-pedido .fluent-dialog-main {
            --dialog-width: 90% !important;
            --dialog-max-height: 90vh !important;
        }
    }

    .autocomplete-estado fluent-anchored-region {
        min-width: 375px;
        max-width: 375px;
    }

    .autocomplete-estado fluent-anchored-region fluent-option {
        margin: 0 0.5em 0 0.2em;
    }
</style>

<LoadingSpinner @bind-Visible="IsLoading" />

<div class="container-modal-pedido">
    <FluentDialog Modal="true" @bind-Hidden="HiddenPedido">
        <FluentHeader>
            <h3>@(Compra == null ? "Nuevo Pedido" : "Editar Pedido")</h3>
        </FluentHeader>

        <FluentDialogBody Style="overflow-y:auto; max-height: calc(80vh - 120px);">
            <div style="padding: 0 1em;">
                <div class="nueva-fila" style="margin-bottom: 0;">
                    <div class="columna-flex" style="padding-top: 1em;">
                        <FluentTextField @bind-Value="Numero"
                                         Label="Número"
                                         Placeholder="Ingrese el número de pedido"
                                         Style="width:100%" />
                    </div>
                </div>
                <div class="nueva-fila" style="margin-bottom: 0;">
                    <div class="columna-flex" style="padding-top: 1em;">
                        <FluentAutocomplete Label="Cliente"
                                            Items="@ClientesFiltrados"
                                            TOption="Cliente"
                                            AutoComplete="off"
                                            Placeholder="Seleccione un cliente"
                                            Class="autocomplete-opti"
                                            @bind-SelectedOption="ClienteSelect"
                                            OptionText="@(c => c.Nombre)"
                                            Virtualize="true"
                                            Multiple="false"
                                            MaximumSelectedOptions="1"
                                            OnOptionsSearch="@OnBuscarCliente"
                                            MaximumOptionsSearch="int.MaxValue"
                                            Position="SelectPosition.Below"
                                            ReadOnly="@(ClienteConsulta != null)"/>
                    </div>
                </div>
                <div class="fila-flex" style="margin-bottom: 0;">
                    <div class="columna-flex" style="padding-top: 1em;">
                        <FluentDatePicker Label="Fecha"
                                          @bind-Value="Fecha"
                                          Style="width:100%" />
                    </div>
                    <div class="columna-flex" style="padding-top: 1em;">
                        <FluentAutocomplete Label="Estado"
                                            Items="Estados"
                                            TOption="KeyValuePair<string, bool>"
                                            AutoComplete="off"
                                            Class="autocomplete-estado"
                                            @bind-SelectedOption="EstadoSeleccionado"
                                            OptionText="@(e => e.Key)"
                                            Multiple="false"
                                            MaximumSelectedOptions="1"
                                            Style="width:100%" />
                    </div>
                </div>
                <div class="fila-flex" style="margin-bottom: 0;">
                    <div class="columna-flex" style="padding: 1em 0;">
                        <FluentTextField Label="Laboratorio"
                                        @bind-Value="Laboratorio"
                                        Placeholder="Ingrese el laboratorio"
                                        Style="width:100%" />
                    </div>
                </div>
                <FluentCard AreaRestricted="false" Class="data-grid-table" Style="margin-bottom: 1em; padding: 0.5em;">
                    @if (Permisos.CanEdit("/pedido"))
                    {
                        <div class="column-flex">
                            <FluentButton Appearance="Appearance.Accent"
                                          OnClick="AbrirArticulos"
                                          IconStart="@(new Icons.Filled.Size20.AddCircle())"
                                          Style="margin: 1em;">
                                Agregar Artículo
                            </FluentButton>
                        </div>
                    }
                    <div class="column-flex">
                        <FluentDataGrid Items="ListDetCompras"
                                        TGridItem="DetCompra"
                                        AutoFit=false
                                        ShowHover=true>
                            <PropertyColumn Property="tbl => tbl.Cantidad" Title="Cantidad" Sortable="true" />
                            <PropertyColumn Property="tbl => tbl.Articulo.Nombre" Title="Articulo" Sortable="true" IsDefaultSortColumn />
                            <TemplateColumn Title="Acción">
                                <ChildContent Context="det">
                                    <div style="display:flex; justify-content:center; align-items:center; height:100%;">
                                        <FluentButton Class="btn-delete-grid"
                                                      Appearance="Appearance.Stealth"
                                                      OnClick="@(() => EliminarDetalle(det))">
                                            <FluentIcon Value="@(new Icons.Filled.Size20.Delete())" Color="Color.Error"/>
                                        </FluentButton>
                                    </div>
                                </ChildContent>
                            </TemplateColumn>
                        </FluentDataGrid>
                    </div>
                </FluentCard>
            </div>
        </FluentDialogBody>

        <FluentFooter Style="gap:1em">
            <FluentButton Appearance="Appearance.Stealth"
                          OnClick="Cancelar"
                          IconStart="@(new Icons.Filled.Size20.DismissCircle())">
                Cancelar
            </FluentButton>
        
            @if ((Compra != null && Compra?.IdCompra > 0) && Permisos.CanDelete("/pedido"))
            {
                <FluentButton Class="btn-danger"
                              Appearance="Appearance.Neutral"
                              OnClick="Eliminar" >
                    <FluentIcon Value="@(new Icons.Filled.Size20.Delete())" Color="Color.Neutral" Slot="start" />
                    Eliminar
                </FluentButton>
            }
            @if (Permisos.CanEdit("/pedido"))
            {
                <FluentButton Appearance="Appearance.Accent"
                    OnClick="Guardar"
                    IconStart="@(new Icons.Filled.Size20.Save())">
                        Guardar
                    </FluentButton>
            }
        </FluentFooter>
    </FluentDialog>
</div>

@if (!HiddenArticulo)
{
    <ArticuloDiag HiddenArticulo="@HiddenArticulo"
                  HiddenArticuloChanged="@(v => HiddenArticulo = v)"
                  Articulos="Articulos"
                  OnArticuloAgregado="ArticuloAgregado" />
}

@code {
    [Parameter] public bool HiddenPedido { get; set; }
    [Parameter] public EventCallback<bool> HiddenPedidoChanged { get; set; }
    [Parameter] public EventCallback<Compra> OnGuardar { get; set; }
    [Parameter] public EventCallback OnEliminar { get; set; }
    [Parameter] public Compra? Compra { get; set; }
    [Parameter] public List<DetCompra>? DetCompras { get; set; }
    [Parameter] public List<Cliente>? Clientes { get; set; }
    [Parameter] public Cliente? ClienteConsulta { get; set; }

    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    private string? Numero;
    private string? Laboratorio;
    private DateTime? Fecha = DateTime.Today;
    private Cliente? ClienteSelect = new();
    private List<DetCompra> _detalles = new(); 
    private List<Articulo> Articulos { get; set; } = new();
    private IQueryable<DetCompra>? ListDetCompras;
    private bool HiddenArticulo = true;
    private bool IsLoading = false;

    private List<Cliente> ClientesFiltrados = new();

    private Dictionary<string, bool> Estados = new()
    {
        { "Pendiente", false },
        { "Finalizado", true }
    };

    private KeyValuePair<string, bool> EstadoSeleccionado;

    protected override void OnParametersSet()
    {
        ClientesFiltrados = Clientes?.ToList() ?? new List<Cliente>();

        if (Compra != null)
        {
            ClienteSelect = Clientes!.FirstOrDefault(c => c.IdCliente == Compra.IdCliente);

            Numero = Compra.Numero;
            Fecha = Compra.Fecha;
            Laboratorio = Compra.Laboratorio;

            EstadoSeleccionado = Estados
                .First(e => e.Value == Compra.Finalizado);

            _detalles = DetCompras != null
                ? DetCompras.Select(d => new DetCompra
                {
                    IdDetCompra = d.IdDetCompra,
                    IdArticulo = d.IdArticulo,
                    Articulo = d.Articulo,
                    Cantidad = d.Cantidad
                }).ToList()
                : new List<DetCompra>();

            ListDetCompras = _detalles.AsQueryable();
        }
        else
        {
            Numero = null;
            Fecha = DateTime.Today;
            Laboratorio = null;
            ClienteSelect = ClienteConsulta;
            EstadoSeleccionado = Estados.First(e => e.Value == false);
            _detalles = new List<DetCompra>();
            ListDetCompras = _detalles.AsQueryable();
        }
    }

    private async Task Guardar()
    {
        var pedido = Compra ?? new Compra();

        pedido.Numero = Numero;
        pedido.Fecha = Fecha;
        pedido.Laboratorio = Laboratorio;
        pedido.Cliente = ClienteSelect;
        pedido.Finalizado = EstadoSeleccionado.Value;

        bool isValido = true;

        try
        {
            IsLoading = true;
            StateHasChanged();

            if (string.IsNullOrEmpty(pedido.Numero))
            {
                ToastService.ShowError("Debe registrar el número del pedido.", 6000);
                isValido = false;
            }

            if (pedido.Cliente == null || pedido.IdCliente == 0)
            {
                ToastService.ShowError("Debe seleccionar un cliente.", 6000);
                isValido = false;
            }

            if (!isValido)
                return;

            await CompraService.GuardarCompraAsync(pedido);
            await DetCompraService.GuardarDetallesAsync(pedido.IdCompra, _detalles);
            await OnGuardar.InvokeAsync(pedido);
            await Cancelar();
            Limpiar();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al guardar el pedido: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task Cancelar()
    {
        Limpiar();
        HiddenPedido = true;
        await HiddenPedidoChanged.InvokeAsync(HiddenPedido);
    }

    private async Task Eliminar()
    {
        if (Compra == null || Compra.IdCompra <= 0)
        {
            ToastService.ShowWarning("No hay un pedido válido para eliminar.", 4000);
            return;
        }

        var confirmado = await ConfirmService.ConfirmAsync("¿Está seguro de eliminar este pedido?");
        if (!confirmado)
            return;

        try
        {
            IsLoading = true;
            StateHasChanged();

            await DetCompraService.EliminarDetCompraAsync(Compra.IdCompra);
            await CompraService.EliminarCompraAsync(Compra.IdCompra);

            await OnEliminar.InvokeAsync();
            await Cancelar();
            Limpiar();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al eliminar el pedido: {ex.Message}", 6000);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task AbrirArticulos()
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            if (!Articulos.Any())
                Articulos = await ArticuloService.ObtenerArticulosAsync();

            HiddenArticulo = false;
            IsLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al cargar artículos: {ex.Message}", 5000);
        }
    }

    private void ArticuloAgregado(ArticuloAgregadoEvent articulo)
    {
        _detalles.Add(new DetCompra
        {
            IdArticulo = articulo.Articulo.IdArticulo,
            Articulo = articulo.Articulo,
            Cantidad = articulo.Cantidad <= 0 ? 1 : articulo.Cantidad
        });

        ListDetCompras = _detalles.AsQueryable();

        StateHasChanged();
    }

    private void EliminarDetalle(DetCompra detalle)
    {
        _detalles.Remove(detalle);

        ListDetCompras = _detalles.AsQueryable();

        StateHasChanged();
    }

    private void Limpiar()
    {
        Numero = null;
        Fecha = DateTime.Now;
        Laboratorio = null;
        ClienteSelect = null;
        EstadoSeleccionado = Estados.First(e => e.Value == false);
        _detalles = new List<DetCompra>();
        ListDetCompras = _detalles.AsQueryable();
    }

    private void OnBuscarCliente(OptionsSearchEventArgs<Cliente> e)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(e.Text))
            {
                e.Items = ClientesFiltrados; // mostrar todo si no escribe
                return;
            }

            string texto = e.Text.Trim().ToLower();

            // Primero coincidencias al inicio del nombre
            var inicio = ClientesFiltrados
                .Where(c => c.Nombre?.ToLower().StartsWith(texto) == true);

            // Luego coincidencias en medio o final
            var medio = ClientesFiltrados
                .Where(c => c.Nombre?.ToLower().Contains(texto) == true
                            && !c.Nombre.ToLower().StartsWith(texto));

            e.Items = inicio.Concat(medio).ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al buscar cliente: {ex.Message}", 5000);
            e.Items = ClientesFiltrados; // fallback
        }
    }

}
