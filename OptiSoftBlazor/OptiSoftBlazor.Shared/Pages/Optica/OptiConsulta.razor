@page "/consulta"
@attribute [Authorize(Policy = "RequirePasswordChanged")]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Helpers
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Services

@inject ConsultaService ConsultaService
@inject ClienteService ClienteService
@inject PersonalService PersonalService
@inject CompraService CompraService
@inject IJSRuntime JS

<style>
    .autocomplete-opti fluent-anchored-region {
        min-width: 600px;
        max-width: 600px;
    }
</style>

<PageTitle>Consulta</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

<div class="op-page">

    @if (!IsFirstRender)
    {
        <div class="op-topbar">
            <div class="op-topbar-left">
                @* <div class="op-greet">🗂️ Historial clínico</div> *@
                <div class="op-title">🗂️ Consultas</div>
            </div>
            <div class="op-topbar-right">

                @if (ListConsultas != null)
                {
                    <div class="op-stat-chip">
                        Total: <strong>@ListConsultas.Count()</strong>
                    </div>
                }

                <div class="op-search">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#8a8fbf" stroke-width="2">
                        <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
                    </svg>
                    <input placeholder="Buscar por cliente, profesional o pedido..."
                           autocomplete="off"
                           value="@TextoBusqueda"
                           @oninput="OnSearchInput" />
                </div>

                <button class="op-btn op-btn-ghost"
                        @onclick="LimpiarFiltro"
                        disabled="@(string.IsNullOrEmpty(TextoBusqueda))"
                        title="Limpiar filtro">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>

                @if (Permisos.CanCreate("/consulta"))
                {
                    <button class="op-btn" @onclick="AddConsulta">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" />
                        </svg>
                        Nueva consulta
                    </button>
                }
            </div>
        </div>
    }

    @if (ListConsultas != null)
    {
        <div class="op-card">
            <div class="op-card-header">
                <span class="op-card-title">Listado de consultas</span>
                @if (!string.IsNullOrWhiteSpace(TextoBusqueda))
                {
                    <span class="op-card-count">@ListConsultas.Count() resultado(s) para "@TextoBusqueda"</span>
                }
            </div>

            @{
                var paginados    = ListConsultas.Skip(PaginaActual * ItemsPorPagina).Take(ItemsPorPagina).ToList();
                var totalPaginas = (int)Math.Ceiling(ListConsultas.Count() / (double)ItemsPorPagina);
            }

            @if (!paginados.Any())
            {
                <div class="op-empty">
                    <span class="op-empty-icon">🔍</span>
                    No se encontraron consultas con ese criterio.
                </div>
            }
            else
            {
                <table class="op-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>N° Pedido</th>
                            <th>Profesional</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tbl in paginados)
                        {
                            <tr @onclick="@(() => OnRowClicked(tbl))">
                                <td class="td-date">@(tbl.Fecha?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                                <td class="td-name">@tbl.Cliente?.Nombre</td>
                                <td class="td-code">@tbl.PedidoNumero</td>
                                <td class="td-muted">@tbl.Profesional?.Nombre</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (totalPaginas > 1)
                {
                    <div class="op-pagination">
                        <span class="op-page-info">
                            Página @(PaginaActual + 1) de @totalPaginas
                        </span>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual == 0)"
                                @onclick="() => CambiarPagina(PaginaActual - 1)">
                            ‹
                        </button>
                        <button class="op-page-btn"
                                disabled="@(PaginaActual >= totalPaginas - 1)"
                                @onclick="() => CambiarPagina(PaginaActual + 1)">
                            ›
                        </button>
                    </div>
                }
            }
        </div>
    }

</div>

@if (!HiddenConsulta)
{
    <ConsultaDiag HiddenConsulta="@HiddenConsulta"
                  Consulta="ConsultaSeleccionada"
                  HiddenConsultaChanged="@(v => HiddenConsulta = v)"
                  Clientes="@Clientes"
                  Personales="@Personales"
                  Pedidos="@Pedidos"
                  OnGuardar="GuardarConsulta"
                  OnEliminar="EliminarConsulta" />
}

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Consulta>? consultas = new();
    private List<Consulta>? consultasFiltradas = new();
    bool HiddenConsulta = true;
    private List<Cliente> Clientes = new();
    private List<Personal> Personales = new();
    private List<Compra> Pedidos = new();
    bool IsFirstRender = true;
    private Consulta? ConsultaSeleccionada;
    private IQueryable<Consulta>? ListConsultas;
    private string? TextoBusqueda;

    private bool IsLoading { get; set; } = false;

    // Paginación propia
    private int PaginaActual   = 0;
    private int ItemsPorPagina = 10;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!Permisos.CanView("/consulta"))
            NavManager.NavigateTo("/noaccess");

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            consultas = await ConsultaService.ObtenerConsultasAsync();
            consultasFiltradas = new List<Consulta>(consultas);
            Clientes = await ClienteService.ObtenerClienteAsync();
            ListConsultas = consultasFiltradas.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cargar los datos.", 5000);
            Console.WriteLine($"Error al cargar los datos: {ex}");
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddConsulta()
    {
        await CargarDatos();

        ConsultaSeleccionada = null;
        HiddenConsulta = false;
        StateHasChanged();
    }

    private async Task GuardarConsulta(Consulta consulta)
    {
        consultas = await ConsultaService.ObtenerConsultasAsync();
        consultasFiltradas = new List<Consulta>(consultas);
        ListConsultas = consultasFiltradas.AsQueryable();
        ToastService.ShowSuccess("Consulta guardada correctamente");
    }

    private async Task EliminarConsulta()
    {
        consultas = await ConsultaService.ObtenerConsultasAsync();
        consultasFiltradas = new List<Consulta>(consultas);
        ListConsultas = consultasFiltradas.AsQueryable();
        ToastService.ShowSuccess("La consulta ha sido eliminada correctamente");
    }

    private async Task OnRowClicked(Consulta consulta)
    {
        if (consulta.IdConsulta <= 0)
            return;

        await CargarDatos();

        ConsultaSeleccionada = consulta;
        HiddenConsulta = false;
        StateHasChanged();
    }

    private void LimpiarFiltro()
    {
        TextoBusqueda = null;
        PaginaActual  = 0;
        FiltrarConsultas();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        TextoBusqueda = e.Value?.ToString();
        PaginaActual  = 0;
        FiltrarConsultas();
    }

    private void FiltrarConsultas()
    {
        if (consultas == null)
            return;

        if (string.IsNullOrWhiteSpace(TextoBusqueda))
        {
            consultasFiltradas = new List<Consulta>(consultas);
        }
        else
        {
            var texto = TextoBusqueda.Trim().ToLower();

            consultasFiltradas = consultas
                .Where(p =>
                    (!string.IsNullOrEmpty(p.Cliente?.Nombre)      && p.Cliente.Nombre.ToLower().Contains(texto)) ||
                    (!string.IsNullOrEmpty(p.Profesional?.Nombre)  && p.Profesional.Nombre.ToLower().Contains(texto)) ||
                    (!string.IsNullOrEmpty(p.PedidoNumero)         && p.PedidoNumero.ToLower().Contains(texto))
                )
                .ToList();
        }

        ListConsultas = consultasFiltradas.AsQueryable();
        StateHasChanged();
    }

    private void CambiarPagina(int nuevaPagina)
    {
        PaginaActual = nuevaPagina;
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            if (!Clientes.Any())
                Clientes = await ClienteService.ObtenerClienteAsync();

            if (!Pedidos.Any())
                Pedidos = await CompraService.ObtenerPedidosAsync();

            if (!Personales.Any())
                Personales = await PersonalService.ObtenerPersonalAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al cargar datos: {ex.Message}", 5000);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
