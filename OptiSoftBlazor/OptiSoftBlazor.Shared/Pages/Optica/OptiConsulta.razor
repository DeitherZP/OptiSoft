@page "/consulta"
@attribute [Authorize]
@rendermode InteractiveServer

@using OptiSoftBlazor.Shared.Data
@using OptiSoftBlazor.Shared.Pages.Shared
@using OptiSoftBlazor.Shared.Pages.Optica.Shared
@using OptiSoftBlazor.Shared.Services

@inject ConsultaService ConsultaService
@inject ClienteService ClienteService
@inject PersonalService PersonalService
@inject CompraService CompraService
@inject IJSRuntime JS

<style>
    .autocomplete-opti fluent-anchored-region {
        min-width: 600px;
        max-width: 600px;
    }
</style>

<PageTitle>Consulta</PageTitle>

<LoadingSpinner @bind-Visible="IsLoading" />

@if (!IsFirstRender)
{
    <div class="nueva-fila">
        <FluentButton Appearance="Appearance.Accent" OnClick="AddConsulta" IconStart="@(new Icons.Filled.Size20.AddCircle())" Style="margin-top: 1.45em; margin-right: 3em">Nuevo</FluentButton>

        <FluentAutocomplete Label="Cliente"
                            Items="Clientes"
                            TOption="Cliente"
                            Class="autocomplete-opti"
                            @bind-SelectedOption="ClienteSelect"
                            OptionText="@(c => c.Nombre)"
                            Virtualize="true"
                            Multiple="false"
                            MaximumOptionsSearch="int.MaxValue"
                            MaximumSelectedOptions="1"
                            Position="SelectPosition.Below"
                            @bind-SelectedOption:after="FiltrarPorCliente"
                            Style="width: 300px; margin-right: 1em;" />

        <FluentButton Appearance="Appearance.Accent" OnClick="LimpiarFiltro" IconStart="@(new Icons.Filled.Size20.FilterDismiss())" Style="margin-top: 1.45em;" Disabled="!(ClienteSelect?.idCliente > 0)" />
    </div>
}

@if (!(ListConsultasFiltradas == null))
{
    <FluentCard AreaRestricted="false" Class="data-grid-table" Style="max-height: 78vh; padding: 0.5em;">
        <FluentDataGrid Items="ListConsultasFiltradas"
                        TGridItem="Consulta"
                        Pagination="@pagination"
                        AutoFit=true
                        ShowHover=true
                        DisplayMode="DataGridDisplayMode.Table"
                        OnRowClick="@(args => OnRowClicked(args.Item ?? new()))">
            <PropertyColumn Property="tbl => tbl.Fecha" Title="Fecha" Sortable="true" Format="dd/MM/yyyy" Align="Align.Center" IsDefaultSortColumn InitialSortDirection="SortDirection.Descending" />
            <PropertyColumn Property="tbl => tbl.Cliente!.Nombre" Title="Cliente" Sortable="true" Align="Align.Center" />
            <PropertyColumn Property="tbl => tbl.PedidoNumero" Title="N° Pedido" Sortable="true" Align="Align.Center" />
            <PropertyColumn Property="tbl => tbl.Profesional!.Nombre" Title="Profesional" Sortable="true" Align="Align.Center" />
        </FluentDataGrid>
        @if (ListConsultasFiltradas.Count() > pagination.ItemsPerPage)
        {
            <FluentPaginator State="pagination" Style="padding: 0.5em 2em;" />
        }
    </FluentCard>
}

@if (!Hidden)
{
    <ConsultaDiag Hidden="@Hidden"
                  Consulta="ConsultaSeleccionada"
                  HiddenChanged="@(v => Hidden = v)"
                  Clientes="@Clientes"
                  Personales="@Personales"
                  Pedidos="@Pedidos"
                  OnGuardar="GuardarConsulta"
                  OnEliminar="EliminarConsulta" />
}

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Consulta>? consultas = new();
    private List<Consulta>? consultasFiltradas = new();
    bool Hidden = true;
    private List<Cliente> Clientes = new();
    private List<Personal> Personales = new();
    private List<Compra> Pedidos = new();
    bool IsFirstRender = true;
    private Consulta? ConsultaSeleccionada;
    private IQueryable<Consulta>? ListConsultasFiltradas;

    private Cliente? ClienteSelect { get; set; }

    private bool IsLoading { get; set; } = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await JS.InvokeVoidAsync("translateFluentLabels");

        try
        {
            IsLoading = true;
            StateHasChanged();
            consultas = await ConsultaService.ObtenerConsultasAsync();
            consultasFiltradas = new List<Consulta>(consultas);
            Clientes = await ClienteService.ObtenerClienteAsync();
            ListConsultasFiltradas = consultasFiltradas.AsQueryable();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cargar los datos.", 5000);
            Console.WriteLine($"Error al cargar los datos: {ex}");
        }
        finally
        {
            IsFirstRender = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddConsulta()
    {
        IsLoading = true;
        StateHasChanged();

        if (!Pedidos.Any())
            Pedidos = await CompraService.ObtenerPedidosAsync();

        if (!Personales.Any())
            Personales = await PersonalService.ObtenerPersonalAsync();

        ConsultaSeleccionada = null; // Nueva consulta
        Hidden = false;

        IsLoading = false;
        StateHasChanged();
    }

    private async Task GuardarConsulta(Consulta consulta)
    {
        consultas = await ConsultaService.ObtenerConsultasAsync();
        consultasFiltradas = new List<Consulta>(consultas);
        ListConsultasFiltradas = consultasFiltradas.AsQueryable();
        ClienteSelect = null; // Limpiar filtro después de guardar
        ToastService.ShowSuccess("Consulta guardada correctamente");
    }

    private async Task EliminarConsulta()
    {
        consultas = await ConsultaService.ObtenerConsultasAsync();
        consultasFiltradas = new List<Consulta>(consultas);
        ListConsultasFiltradas = consultasFiltradas.AsQueryable();
        ClienteSelect = null; // Limpiar filtro después de eliminar
        ToastService.ShowSuccess("La consulta ha sido eliminada correctamente");
    }

    private async Task OnRowClicked(Consulta consulta)
    {
        if (consulta.IdConsulta <= 0)
            return;

        IsLoading = true;
        StateHasChanged();

        if (!Pedidos.Any())
            Pedidos = await CompraService.ObtenerPedidosAsync();

        if (!Personales.Any())
            Personales = await PersonalService.ObtenerPersonalAsync();

        ConsultaSeleccionada = consulta;
        Hidden = false;

        IsLoading = false;
        StateHasChanged();
    }

    private void LimpiarFiltro()
    {
        ClienteSelect = null;
        FiltrarPorCliente();
    }

    private void FiltrarPorCliente()
    {
        if (consultas == null) return;

        if (ClienteSelect?.idCliente > 0)
        {
            consultasFiltradas = consultas
                .Where(c => c.Cliente?.idCliente == ClienteSelect.idCliente)
                .ToList();
        }
        else
        {
            consultasFiltradas = new List<Consulta>(consultas);
        }

        ListConsultasFiltradas = consultasFiltradas.AsQueryable();
        StateHasChanged();
    }
}