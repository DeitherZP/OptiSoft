@using Microsoft.AspNetCore.Identity
@using OptiSoftBlazor.Shared.Data.RolePermission
@using OptiSoftBlazor.Shared.Data.RolePermission.Dto
@using OptiSoftBlazor.Shared.Pages.Shared

@inject RolesService RolesService

<style>
    .container-modal-role .fluent-dialog-main {
        --dialog-width: 850px !important;
        --dialog-max-height: 90vh !important;
    }

    @@media (max-width: 600px) {
        .container-modal-role .fluent-dialog-main {
            --dialog-width: 90% !important;
            --dialog-max-height: 90vh !important;
        }
    }
</style>

<LoadingSpinner @bind-Visible="IsLoading" />

<div class="container-modal-role">
    <FluentDialog Modal="true" @bind-Hidden="HiddenRole">
        <FluentHeader>
            <h3>@(Role == null ? "Nuevo Rol" : "Editar Rol")</h3>
        </FluentHeader>

        <FluentDialogBody Style="overflow-y:auto; max-height: calc(80vh - 120px);">
            <div style="padding: 1em;">
                <div class="nueva-fila" style="margin-bottom: 1em;">
                    <div class="columna-flex">
                        <FluentTextField @bind-Value="RoleName"
                                         Label="Nombre del Rol"
                                         Placeholder="Ingrese el nombre del rol" />
                    </div>
                </div>

                <FluentCard AreaRestricted="false" Class="data-grid-table" Style="max-height: fit-content; padding: 0.5em;">
                    <FluentDataGrid Items="AuxPermisos"
                                    TGridItem="ScreenPermissionView"
                                    AutoFit="true" >
                        <PropertyColumn Property="s => s.ScreenName" Title="Pantalla" Align="Align.Center" />
                        <TemplateColumn Title="Crear" Align="Align.Center">
                            <ChildContent Context="s">
                                <FluentCheckbox @bind-Value="s.CanCreate" />
                            </ChildContent>
                        </TemplateColumn>
                        <TemplateColumn Title="Ver" Align="Align.Center">
                            <ChildContent Context="s">
                                <FluentCheckbox @bind-Value="s.CanView" />
                            </ChildContent>
                        </TemplateColumn>
                        <TemplateColumn Title="Editar" Align="Align.Center">
                            <ChildContent Context="s">
                                <FluentCheckbox @bind-Value="s.CanEdit" />
                            </ChildContent>
                        </TemplateColumn>
                        <TemplateColumn Title="Eliminar" Align="Align.Center">
                            <ChildContent Context="s">
                                <FluentCheckbox @bind-Value="s.CanDelete" />
                            </ChildContent>
                        </TemplateColumn>

                    </FluentDataGrid>
                </FluentCard>
            </div>
        </FluentDialogBody>

        <FluentFooter Style="gap:1em">
            <FluentButton Appearance="Appearance.Stealth"
                          OnClick="Cancelar"
                          IconStart="@(new Icons.Filled.Size20.DismissCircle())">
                Cancelar
            </FluentButton>

            @if ((Role != null && !string.IsNullOrEmpty(Role?.RoleId)) && Permisos.CanDelete("/permisos"))
            {
                <FluentButton Class="btn-danger"
                              Appearance="Appearance.Neutral"
                              OnClick="Eliminar">
                    <FluentIcon Value="@(new Icons.Filled.Size20.Delete())" Color="Color.Neutral" Slot="start" />
                    Eliminar
                </FluentButton>
            }

            @if (Permisos.CanEdit("/permisos"))
            {
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="Guardar"
                              IconStart="@(new Icons.Filled.Size20.Save())">
                    Guardar
                </FluentButton>
            }
        </FluentFooter>
    </FluentDialog>
</div>

@code {
    [Parameter] public bool HiddenRole { get; set; } = true;
    [Parameter] public EventCallback<bool> HiddenRoleChanged { get; set; }
    [Parameter] public EventCallback OnGuardar { get; set; }
    [Parameter] public EventCallback OnEliminar { get; set; }
    [Parameter] public RoleView? Role { get; set; }
    [Parameter] public List<ScreenPermissionView>? ListPermisos { get; set; }
    [Parameter] public List<AppScreen>? Screens { get; set; }

    private bool IsLoading = false;

    private string? RoleName;
    private IQueryable<ScreenPermissionView>? AuxPermisos => PermisosList.AsQueryable();
    private List<ScreenPermissionView> PermisosList = new();

    protected override void OnParametersSet()
    {
        if (Role != null)
        {
            RoleName = Role?.RoleName;

            PermisosList = ListPermisos?
                .OrderBy(x => x.ScreenName)
                .ToList() ?? new();
        }
        else
        {
            RoleName = string.Empty;

            PermisosList = Screens?
                .Select(s => new ScreenPermissionView
                {
                    ScreenId = s.Id,
                    ScreenName = s.CodePage,
                    CanView = false,
                    CanCreate = false,
                    CanEdit = false,
                    CanDelete = false
                })
                .Where(s => !string.IsNullOrEmpty(s.ScreenName))
                .OrderBy(s => s.ScreenName)
                .ToList() ?? new();
        }
    }

    private async Task Cancelar()
    {
        Limpiar();
        HiddenRole = true;
        await HiddenRoleChanged.InvokeAsync(HiddenRole);
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(RoleName))
        {
            ToastService.ShowWarning("Debe ingresar un nombre para el rol.");
            return;
        }

        IsLoading = true;
        StateHasChanged();

        try
        {
            await RolesService.GuardarRolAsync(
                Role?.RoleId,
                RoleName,
                PermisosList
            );

            await OnGuardar.InvokeAsync();

            HiddenRole = true;
            await HiddenRoleChanged.InvokeAsync(HiddenRole);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al guardar: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task Eliminar()
    {
        if (Role == null || string.IsNullOrEmpty(Role.RoleId))
            return;

        var confirmado = await ConfirmService.ConfirmAsync($"¿Está seguro que desea eliminar el rol '{Role.RoleName}'?");

        if (!confirmado)
            return;

        IsLoading = true;
        StateHasChanged();

        try
        {
            await RolesService.EliminarRolAsync(Role.RoleId);
            await OnEliminar.InvokeAsync();

            HiddenRole = true;
            await HiddenRoleChanged.InvokeAsync(HiddenRole);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al eliminar el rol: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void Limpiar()
    {
        RoleName = null;
        Role = null;
        Screens = null;
    }
}
