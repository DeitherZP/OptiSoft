@page "/Account/PasswordChanged"
@attribute [Authorize]
@layout MinimalLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http
@using OptiSoftBlazor.Shared.Services
@inject NavigationManager Nav
@inject UsuariosService UsuariosService
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Cambio de Contraseña</PageTitle>

<FluentCard Style="width: 450px; padding: 2em;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">

        <div style="width: 100%; text-align: center; margin-bottom: 1em;">
            <h1 style="margin: 0.5em 0;">OptiSoft</h1>
            <p style="margin: 0; color: var(--warning);">⚠ Debe cambiar su contraseña para continuar</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <FluentMessageBar Intent="MessageIntent.Error" Style="width:100%;">
                @_errorMessage
            </FluentMessageBar>
        }

        @if (_success)
        {
            <FluentMessageBar Intent="MessageIntent.Success" Style="width:100%;">
                Contraseña actualizada correctamente. Redirigiendo...
            </FluentMessageBar>
        }
        else
        {
            <div class="fila-flex">
                <div class="columna-flex">
                    <FluentTextField @bind-Value="_newPassword"
                                     Label="Nueva contraseña"
                                     TextFieldType="TextFieldType.Password"
                                     Required
                                     Style="width: 100%" />
                </div>
            </div>

            <div class="fila-flex">
                <div class="columna-flex">
                    <FluentTextField @bind-Value="_confirmPassword"
                                     Label="Repetir contraseña"
                                     TextFieldType="TextFieldType.Password"
                                     Required
                                     Style="width: 100%" />
                </div>
            </div>

            @if (_requirements.Any())
            {
                <ul style="margin: 0; padding-left: 1.4em; font-size: 0.85em; color: var(--neutral-foreground-hint);">
                    @foreach (var req in _requirements)
                    {
                        <li style="color: @(req.Met ? "var(--success)" : "var(--error)")">
                            @(req.Met ? "✔" : "✘") @req.Text
                        </li>
                    }
                </ul>
            }

            <div class="fila-flex">
                <div class="columna-flex">
                    <FluentButton Appearance="Appearance.Accent"
                                  Style="width:100%;"
                                  Disabled="@(!CanSubmit || _loading)"
                                  OnClick="HandleChangePassword">
                        @(_loading ? "Actualizando..." : "Cambiar contraseña")
                    </FluentButton>
                </div>
            </div>
        }

    </FluentStack>
</FluentCard>

@code {
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string? _errorMessage;
    private bool _success;
    private bool _loading;

    private record Requirement(string Text, bool Met);

    private List<Requirement> _requirements => new()
    {
        new("Mínimo 12 caracteres",              _newPassword.Length >= 12),
        new("Al menos una mayúscula",             _newPassword.Any(char.IsUpper)),
        new("Al menos una minúscula",             _newPassword.Any(char.IsLower)),
        new("Al menos un número",                 _newPassword.Any(char.IsDigit)),
        new("Al menos un carácter especial",      _newPassword.Any(c => !char.IsLetterOrDigit(c))),
        new("Las contraseñas coinciden",          !string.IsNullOrEmpty(_confirmPassword) && _newPassword == _confirmPassword),
    };

    private bool CanSubmit => _requirements.All(r => r.Met);

    private async Task HandleChangePassword()
    {
        _errorMessage = null;
        _loading = true;

        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name;

            if (string.IsNullOrEmpty(username))
            {
                _errorMessage = "No se pudo identificar al usuario. Inicie sesión nuevamente.";
                return;
            }

            var result = await UsuariosService.CambiarPasswordAsync(username, _newPassword);

            if (result)
            {
                _success = true;
                await Task.Delay(1500);
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = "No se pudo actualizar la contraseña. Intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}